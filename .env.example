# VidVault Environment Configuration
# Copy this file to .env and update the values

# PostgreSQL Configuration
POSTGRES_USER=vidvault_admin
POSTGRES_PASSWORD=CHANGE_THIS_TO_A_STRONG_PASSWORD_MIN_32_CHARS
POSTGRES_DB=vidvault
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/vidvault

# JWT Secret (generate with: openssl rand -base64 48)
JWT_SECRET=CHANGE_THIS_TO_A_RANDOM_64_CHAR_STRING

# Redis Configuration
REDIS_PASSWORD=CHANGE_THIS_TO_A_REDIS_PASSWORD_MIN_32_CHARS
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379

# API Configuration
API_PORT=5000
NODE_ENV=production

# Frontend (set to your domain or leave empty for localhost)
NEXT_PUBLIC_API_URL=

# Authelia 2FA (Optional - only needed if using Authelia)
# Generate with: openssl rand -base64 32
AUTHELIA_JWT_SECRET=
AUTHELIA_SESSION_SECRET=
AUTHELIA_STORAGE_ENCRYPTION_KEY=
AUTHELIA_LDAP_PASSWORD=
